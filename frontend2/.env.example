# Environment variables
# Copy this file to .env.development for dev run configuration
# Copy this file to .env.production for prod build configuration
# DO NOT commit .env.* to git
VITE_APP_NAME="Nexus Hub"

# Keep empty for same-origin (proxied) dev server.
# In production builds, set this to backend URL if hosting separately.
VITE_API_BASE_URL=

# Used in dev run only
# Proxy API requests to backend server to avoid CORS issues.
VITE_BACKEND_PROXY=http://localhost:8000
